// InjenioRw — Prisma Schema
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum Role {
  ENGINEER
  CLIENT
  ADMIN
}

enum Discipline {
  CIVIL
  STRUCTURAL
  MECHANICAL
  ELECTRICAL
  ENVIRONMENTAL
  GEOTECHNICAL
  TRANSPORTATION
  WATER_RESOURCES
  INDUSTRIAL
  AEROSPACE
  CHEMICAL
  MINING
  OTHER
}

enum AvailabilityStatus {
  AVAILABLE
  BUSY
  UNAVAILABLE
}

enum JobType {
  HOURLY
  FIXED
  MILESTONE
}

enum JobStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  PAUSED
}

enum ExperienceLevel {
  JUNIOR
  MID
  SENIOR
  EXPERT
}

enum ProposalStatus {
  PENDING
  SHORTLISTED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum ContractStatus {
  ACTIVE
  PAUSED
  COMPLETED
  DISPUTED
  CANCELLED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  APPROVED
  REJECTED
  PAID
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  MTN_MOMO
  AIRTEL_MONEY
  BANK_TRANSFER
  STRIPE
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum MessageType {
  TEXT
  FILE
  SYSTEM
  PROPOSAL
  MILESTONE_UPDATE
}

enum NotificationType {
  PROPOSAL_RECEIVED
  PROPOSAL_ACCEPTED
  PROPOSAL_REJECTED
  CONTRACT_STARTED
  CONTRACT_COMPLETED
  MILESTONE_SUBMITTED
  MILESTONE_APPROVED
  MILESTONE_REJECTED
  PAYMENT_RECEIVED
  PAYMENT_SENT
  MESSAGE_RECEIVED
  REVIEW_RECEIVED
  PROFILE_VERIFIED
  JOB_POSTED
  NEW_MATCH
}

// ─────────────────────────────────────────────────────────────
// USER (base for Engineer + Client)
// ─────────────────────────────────────────────────────────────

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  passwordHash      String
  role              Role
  firstName         String
  lastName          String
  avatarUrl         String?
  phone             String?
  country           String             @default("RW")
  city              String?
  timezone          String             @default("Africa/Kigali")
  isActive          Boolean            @default(true)
  isEmailVerified   Boolean            @default(false)
  emailVerifyToken  String?
  passwordResetToken String?
  passwordResetExpiry DateTime?
  lastLoginAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  // Relations
  engineerProfile   EngineerProfile?
  clientProfile     ClientProfile?
  sentMessages      Message[]          @relation("SentMessages")
  notifications     Notification[]
  refreshTokens     RefreshToken[]
  reviews           Review[]           @relation("ReviewAuthor")

  @@index([email])
  @@index([role])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────
// ENGINEER PROFILE
// ─────────────────────────────────────────────────────────────

model EngineerProfile {
  id                  String             @id @default(uuid())
  userId              String             @unique
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Professional info
  headline            String?
  bio                 String?
  discipline          Discipline
  otherDisciplines    Discipline[]
  experienceLevel     ExperienceLevel    @default(JUNIOR)
  yearsOfExperience   Int                @default(0)
  hourlyRate          Decimal?           @db.Decimal(10, 2)

  // Status
  availability        AvailabilityStatus @default(AVAILABLE)
  isPublic            Boolean            @default(true)
  isFeatured          Boolean            @default(false)
  verificationStatus  VerificationStatus @default(UNVERIFIED)
  verifiedAt          DateTime?

  // Ratings (computed)
  avgRating           Float              @default(0)
  totalReviews        Int                @default(0)
  completedProjects   Int                @default(0)
  successRate         Float              @default(0)  // JSS equivalent

  // MTN Mobile Money
  momoNumber          String?
  momoName            String?

  // Location
  province            String?
  district            String?

  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  // Relations
  skills              EngineerSkill[]
  portfolio           PortfolioItem[]
  certifications      Certification[]
  education           Education[]
  workHistory         WorkHistory[]
  proposals           Proposal[]
  contracts           Contract[]         @relation("EngineerContracts")
  reviews             Review[]           @relation("EngineerReviews")

  @@index([discipline])
  @@index([availability])
  @@index([avgRating])
  @@index([verificationStatus])
  @@map("engineer_profiles")
}

model EngineerSkill {
  id                String          @id @default(uuid())
  engineerProfileId String
  engineerProfile   EngineerProfile @relation(fields: [engineerProfileId], references: [id], onDelete: Cascade)
  name              String
  level             Int             @default(1) // 1-5
  yearsUsed         Int             @default(0)

  @@unique([engineerProfileId, name])
  @@map("engineer_skills")
}

model PortfolioItem {
  id                String          @id @default(uuid())
  engineerProfileId String
  engineerProfile   EngineerProfile @relation(fields: [engineerProfileId], references: [id], onDelete: Cascade)
  title             String
  description       String
  discipline        Discipline
  imageUrls         String[]
  projectUrl        String?
  completedAt       DateTime?
  client            String?
  highlights        String[]
  createdAt         DateTime        @default(now())

  @@map("portfolio_items")
}

model Certification {
  id                String          @id @default(uuid())
  engineerProfileId String
  engineerProfile   EngineerProfile @relation(fields: [engineerProfileId], references: [id], onDelete: Cascade)
  name              String
  issuer            String
  issueDate         DateTime
  expiryDate        DateTime?
  credentialUrl     String?
  verified          Boolean         @default(false)

  @@map("certifications")
}

model Education {
  id                String          @id @default(uuid())
  engineerProfileId String
  engineerProfile   EngineerProfile @relation(fields: [engineerProfileId], references: [id], onDelete: Cascade)
  institution       String
  degree            String
  fieldOfStudy      String
  startYear         Int
  endYear           Int?
  current           Boolean         @default(false)
  description       String?

  @@map("education")
}

model WorkHistory {
  id                String          @id @default(uuid())
  engineerProfileId String
  engineerProfile   EngineerProfile @relation(fields: [engineerProfileId], references: [id], onDelete: Cascade)
  company           String
  title             String
  startDate         DateTime
  endDate           DateTime?
  current           Boolean         @default(false)
  description       String?

  @@map("work_history")
}

// ─────────────────────────────────────────────────────────────
// CLIENT PROFILE
// ─────────────────────────────────────────────────────────────

model ClientProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName     String?
  companySize     String?  // "1-10", "11-50", "51-200", "200+"
  industry        String?
  website         String?
  description     String?
  logoUrl         String?

  // Verification
  isVerified      Boolean  @default(false)

  // Stats
  totalSpent      Decimal  @default(0) @db.Decimal(12, 2)
  totalJobs       Int      @default(0)
  avgRating       Float    @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  jobs            Job[]
  contracts       Contract[] @relation("ClientContracts")
  reviews         Review[]   @relation("ClientReviews")

  @@map("client_profiles")
}

// ─────────────────────────────────────────────────────────────
// JOB / PROJECT POSTING
// ─────────────────────────────────────────────────────────────

model Job {
  id              String          @id @default(uuid())
  clientProfileId String
  clientProfile   ClientProfile   @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  title           String
  description     String
  discipline      Discipline
  otherDisciplines Discipline[]
  requiredSkills  String[]
  experienceLevel ExperienceLevel
  jobType         JobType
  status          JobStatus       @default(OPEN)

  // Budget
  budgetMin       Decimal?        @db.Decimal(12, 2)
  budgetMax       Decimal?        @db.Decimal(12, 2)
  hourlyRateMin   Decimal?        @db.Decimal(10, 2)
  hourlyRateMax   Decimal?        @db.Decimal(10, 2)

  // Location
  isRemote        Boolean         @default(true)
  location        String?
  province        String?

  // Timeline
  duration        String?         // "1 week", "1-3 months" etc
  startDate       DateTime?
  deadline        DateTime?

  // Metadata
  viewCount       Int             @default(0)
  proposalCount   Int             @default(0)
  attachmentUrls  String[]
  isFeatured      Boolean         @default(false)

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  proposals       Proposal[]
  contract        Contract?

  @@index([discipline])
  @@index([status])
  @@index([jobType])
  @@index([createdAt])
  @@map("jobs")
}

// ─────────────────────────────────────────────────────────────
// PROPOSAL
// ─────────────────────────────────────────────────────────────

model Proposal {
  id                String          @id @default(uuid())
  jobId             String
  job               Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  engineerProfileId String
  engineerProfile   EngineerProfile @relation(fields: [engineerProfileId], references: [id], onDelete: Cascade)

  coverLetter       String
  proposedRate      Decimal         @db.Decimal(10, 2)
  estimatedDuration String
  status            ProposalStatus  @default(PENDING)

  // Milestones in proposal
  milestones        ProposedMilestone[]

  attachmentUrls    String[]
  isShortlisted     Boolean         @default(false)

  clientViewed      Boolean         @default(false)
  clientViewedAt    DateTime?

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  contract          Contract?

  @@unique([jobId, engineerProfileId])
  @@index([jobId])
  @@index([engineerProfileId])
  @@map("proposals")
}

model ProposedMilestone {
  id          String   @id @default(uuid())
  proposalId  String
  proposal    Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  title       String
  description String
  amount      Decimal  @db.Decimal(10, 2)
  dueDate     DateTime?
  order       Int

  @@map("proposed_milestones")
}

// ─────────────────────────────────────────────────────────────
// CONTRACT
// ─────────────────────────────────────────────────────────────

model Contract {
  id                String          @id @default(uuid())
  jobId             String          @unique
  job               Job             @relation(fields: [jobId], references: [id])
  proposalId        String          @unique
  proposal          Proposal        @relation(fields: [proposalId], references: [id])
  engineerProfileId String
  engineerProfile   EngineerProfile @relation("EngineerContracts", fields: [engineerProfileId], references: [id])
  clientProfileId   String
  clientProfile     ClientProfile   @relation("ClientContracts", fields: [clientProfileId], references: [id])

  title             String
  description       String
  status            ContractStatus  @default(ACTIVE)
  jobType           JobType

  totalAmount       Decimal         @db.Decimal(12, 2)
  paidAmount        Decimal         @default(0) @db.Decimal(12, 2)
  escrowAmount      Decimal         @default(0) @db.Decimal(12, 2)

  startDate         DateTime        @default(now())
  endDate           DateTime?
  completedAt       DateTime?

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  milestones        Milestone[]
  payments          Payment[]
  messages          Message[]
  reviews           Review[]

  @@index([engineerProfileId])
  @@index([clientProfileId])
  @@index([status])
  @@map("contracts")
}

model Milestone {
  id          String          @id @default(uuid())
  contractId  String
  contract    Contract        @relation(fields: [contractId], references: [id], onDelete: Cascade)

  title       String
  description String
  amount      Decimal         @db.Decimal(10, 2)
  status      MilestoneStatus @default(PENDING)
  order       Int

  dueDate     DateTime?
  submittedAt DateTime?
  approvedAt  DateTime?
  paidAt      DateTime?

  deliverables  String[]
  attachmentUrls String[]
  feedback      String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  payment     Payment?

  @@index([contractId])
  @@map("milestones")
}

// ─────────────────────────────────────────────────────────────
// PAYMENT
// ─────────────────────────────────────────────────────────────

model Payment {
  id            String        @id @default(uuid())
  contractId    String
  contract      Contract      @relation(fields: [contractId], references: [id])
  milestoneId   String?       @unique
  milestone     Milestone?    @relation(fields: [milestoneId], references: [id])

  amount        Decimal       @db.Decimal(12, 2)
  currency      String        @default("RWF")
  status        PaymentStatus @default(PENDING)
  method        PaymentMethod @default(MTN_MOMO)

  // MTN MoMo specific
  momoReference   String?
  momoPhoneNumber String?
  momoStatus      String?
  momoRawResponse Json?

  platformFee   Decimal       @db.Decimal(10, 2)  // InjenioRw takes ~8%
  netAmount     Decimal       @db.Decimal(12, 2)  // What engineer receives

  paidAt        DateTime?
  failedAt      DateTime?
  failureReason String?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([contractId])
  @@index([status])
  @@map("payments")
}

// ─────────────────────────────────────────────────────────────
// MESSAGING
// ─────────────────────────────────────────────────────────────

model Message {
  id          String      @id @default(uuid())
  contractId  String
  contract    Contract    @relation(fields: [contractId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User        @relation("SentMessages", fields: [senderId], references: [id])

  content     String
  type        MessageType @default(TEXT)
  attachmentUrls String[]
  isRead      Boolean     @default(false)
  readAt      DateTime?

  createdAt   DateTime    @default(now())

  @@index([contractId])
  @@index([senderId])
  @@map("messages")
}

// ─────────────────────────────────────────────────────────────
// REVIEWS
// ─────────────────────────────────────────────────────────────

model Review {
  id                String          @id @default(uuid())
  contractId        String
  contract          Contract        @relation(fields: [contractId], references: [id])
  authorId          String
  author            User            @relation("ReviewAuthor", fields: [authorId], references: [id])

  // Who's being reviewed
  engineerProfileId String?
  engineerProfile   EngineerProfile? @relation("EngineerReviews", fields: [engineerProfileId], references: [id])
  clientProfileId   String?
  clientProfile     ClientProfile?  @relation("ClientReviews", fields: [clientProfileId], references: [id])

  rating            Int             // 1-5
  comment           String
  isPublic          Boolean         @default(true)

  // Sub-ratings
  qualityRating     Int?            // 1-5
  communicationRating Int?          // 1-5
  timelinessRating  Int?            // 1-5
  valueRating       Int?            // 1-5

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([contractId, authorId])
  @@index([engineerProfileId])
  @@map("reviews")
}

// ─────────────────────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}
