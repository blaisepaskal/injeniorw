# ─── InjenioRw Backend — Environment Variables ─────────────────────
# Copy this file to .env and fill in your values

# ── App ──────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database (PostgreSQL) ────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://injeniorw:your_password@localhost:5432/injeniorw_db"

# ── JWT ──────────────────────────────────────────────────────────────
# Generate strong random strings, e.g.: openssl rand -base64 64
JWT_ACCESS_SECRET=change_this_to_a_very_long_random_string_for_access_tokens
JWT_REFRESH_SECRET=change_this_to_a_different_very_long_random_string_for_refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Frontend URL (for CORS) ──────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── MTN Mobile Money ─────────────────────────────────────────────────
# Register at: https://momodeveloper.mtn.com
# For sandbox testing, create a sandbox user via the MoMo API
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_PRIMARY_KEY=your_momo_primary_subscription_key
MTN_MOMO_SECONDARY_KEY=your_momo_secondary_subscription_key
MTN_MOMO_USER_ID=your_momo_user_uuid
MTN_MOMO_API_KEY=your_momo_api_key
MTN_MOMO_ENVIRONMENT=sandbox
MTN_MOMO_CURRENCY=RWF

# ── File Storage (AWS S3 or Cloudflare R2) ───────────────────────────
STORAGE_PROVIDER=local
S3_BUCKET=injeniorw-uploads
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_KEY=your_aws_secret_key

# ── Email (SMTP) ─────────────────────────────────────────────────────
EMAIL_FROM=noreply@injeniorw.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASSWORD=your_gmail_app_password

# ── Platform Fees ────────────────────────────────────────────────────
PLATFORM_FEE_PERCENT=8
